# BankOffer AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=bankofferingai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis123

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Required for AI-powered offer scoring in the worker service.
# Get a key at https://console.anthropic.com
# Without a valid key the worker falls back to rule-based scoring automatically.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_AUDIENCE=bank-offering-api
JWT_ISSUER=bank-auth-service

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123
