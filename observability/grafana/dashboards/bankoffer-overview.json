{
  "title": "BankOffer AI - Platform Overview",
  "uid": "bankoffer-overview",
  "version": 2,
  "schemaVersion": 38,
  "tags": ["bankoffer", "overview"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Offer Acceptance Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(offer_accepted_total[1h])) / sum(rate(offer_displayed_total[1h]))",
          "legendFormat": "Acceptance Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.03 },
              { "color": "green", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Customer Profile Coverage",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(customer_profiles_active) / sum(customer_profiles_total)",
          "legendFormat": "Profile Coverage"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "API p99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "offer_scoring_latency_p99 * 1000",
          "legendFormat": "Offer Scoring p99 (ms)"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "Overall API p99 (ms)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 4,
      "title": "Notification Funnel",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum(increase(notification_sent_total[1h]))", "legendFormat": "Sent" },
        { "expr": "sum(increase(notification_delivered_total[1h]))", "legendFormat": "Delivered" },
        { "expr": "sum(increase(notification_opened_total[1h]))", "legendFormat": "Opened" },
        { "expr": "sum(increase(offer_clicked_total[1h]))", "legendFormat": "Clicked" },
        { "expr": "sum(increase(offer_accepted_total[1h]))", "legendFormat": "Accepted" }
      ],
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "barRadius": 0,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 5,
      "title": "Active Offers by Product Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (product_type) (active_offers_total)",
          "legendFormat": "{{ product_type }}"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        }
      }
    },
    {
      "id": 6,
      "title": "API Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "kafka_consumer_group_lag",
          "legendFormat": "{{ topic }} - {{ consumer_group }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 100000 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "ML Scoring Latency",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ml_scoring_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_scoring_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ml_scoring_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "Notification Delivery Success Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "1 - (sum(rate(notification_delivery_failures_total[5m])) / sum(rate(notification_delivery_attempts_total[5m])))",
          "legendFormat": "Delivery Success Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    }
  ]
}
