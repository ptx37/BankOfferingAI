# BankOffer AI — Local Docker Compose Configuration
# Copy this to .env and adjust as needed

# Database
POSTGRES_DB=bankofferingai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bankofferingai

# Redis
REDIS_URL=redis://:redis123@redis:6379/0
REDIS_PASSWORD=redis123

# Kafka
KAFKA_BROKER=kafka:9092

# API
LOG_LEVEL=info

# Anthropic API (required for ML scoring)
ANTHROPIC_API_KEY=sk-your-key-here

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123
